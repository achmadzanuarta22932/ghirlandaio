[2.7009999999999996, "o", "\u001b[H/e# Configuration file for locale-gen\u001b[2;2H\u001b[19X\n lists of locales that are to be generated by the locale-gen command.\u001b[4;2H\u001b[19X\n Each line is of the form:\u001b[6;2H\u001b[19X\n     <locale> <charset>\u001b[8;2H\u001b[19X\n  where <locale> is one of the locales given in /usr/share/i18n/locales\u001b[10;2H  and <charset> is one of the character sets listed in /usr/share/i18n/charmaps\u001b[11;2H\u001b[13X\n  The locale-gen command will generate all the locales,\u001b[13;2H  placing them in /usr/lib/locale.\u001b[14;2H\u001b[19X\n  A list of supported locales is given in /usr/share/i18n/SUPPORTED\u001b[16;2H  and is included in this file. Uncomment the needed locales below.\u001b[17;2H\u001b[18X\naa_DJ\u001b[19;2Haa_DJ ISO-8859-1   \u001b[20;2Haa_ER UTF-8  \u001b[6X\u001b[21;2Haa_ET UTF-8  \u001b[5X\r\n#af_ZA.UTF-8 UTF-8  \r\n#af_ZA ISO-8859-1  \u001b[24;2Hagr_PE UTF-8  \u001b[5X\u001b[25;2Hak_GH UTF-8  \u001b[5X\u001b[26;2Ham_ET\u001b[27;2Han_ES\u001b[28;2Han_ES ISO-8859-15  \u001b[29;2Hanp_IN UTF-8  \u001b[30;2Har_AE\u001b[31;2Har_AE ISO-8859-6\u001b[32;2Har_BH\u001b[33;2Har_BH ISO-8859-6\u001b[34;2Har_DZ\u001b[35;2Har_DZ ISO-8859-6\u001b[36;2Har_EG\u001b[37;2Har_EG ISO-8859-6\u001b[38;2Har_IN UTF-8  \u001b[6X\u001b[39;2Har_IQ.UTF-8 UTF-8  \u001b[40;2Har_IQ ISO-8859-6  \u001b[41;2Har_J\u001b[42;2Har_JO ISO-8859-6\u001b[43;2Har_KW\u001b[44;143H\u001b[0;10;7m\u000f37,1           Top\u001b[45;8H\u001b[?25h"]
