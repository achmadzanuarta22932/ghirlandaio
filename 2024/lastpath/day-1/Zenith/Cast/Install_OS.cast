[3.66, "o", "\u001b[?2004l\r\r\n"]
[0.019, "o", "==> Creating install root at /mnt\r\n"]
[0.061, "o", "==> Installing packages to /mnt\r\n"]
[0.02, "o", "\u001b[?25l\u001b[1;34m::\u001b[0;1m Synchronizing package databases...\r\n\u001b[0m"]
[0.003, "o", " core\r\n extra\r\n"]
[0.089, "o", "\u001b[2F core is up to date\u001b[K"]
[0.199, "o", "\u001b[1E extra is up to date\u001b[K"]
[0.193, "o", "\u001b[1E"]
[0.272, "o", "\u001b[1;34m::\u001b[0;1m There are 3 providers available for initramfs:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mcore\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) mkinitcpio\r\n\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mextra\r\n\u001b[0m\u001b[0;1m  \u001b[0m 2) booster  3) dracut\r\n\r\nEnter a number (default=1): \r\n"]
[0.025, "o", "\u001b[1;34m::\u001b[0;1m There are 3 providers available for oci-runtime:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mextra\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) crun  2) krun  3) runc\r\n\r\nEnter a number (default=1): \r\n"]
[0.016, "o", "\u001b[1;34m::\u001b[0;1m There are 2 providers available for jack:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mextra\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) jack2  2) pipewire-jack\r\n\r\nEnter a number (default=1): \r\n"]
